{
  "name": "joyful-baseball-tests",
  "version": "1.0.0",
  "description": "Test suite for Joyful Baseball League - Epic 01",
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend && npm run test:integration",
    "test:backend": "cd ../backend && npx jest --config ../tests/backend/jest.config.js --coverage",
    "test:frontend": "cd ../frontend && npx vitest run --config ../tests/frontend/vitest.config.ts --coverage",
    "test:integration": "cd ../backend && npx jest --config ../tests/backend/jest.config.js --testPathPattern=integration",
    "test:watch": "cd ../backend && npx jest --watch",
    "test:coverage": "npm run test:backend -- --coverage"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jsdom": "^24.0.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "vitest": "^1.3.1"
  }
}
